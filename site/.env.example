# Daebak site (Next.js on Vercel) — env. Copy to .env.local for local dev;
# set the same values in the Vercel project (Settings → Environment Variables) for production.
# These are SERVER-SIDE only (used in /api/ask + /questions/status server code). NEVER exposed to the browser.

# ❓ Question inbox (Supabase). Same project as the admin. service_role key — server only.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Random salt for hashing submitter IPs (rate-limit only). Any string; keep it stable.
QUESTION_IP_SALT=

# Public site origin, used to build status links (https://daebak-pi.vercel.app). Falls back to request origin.
NEXT_PUBLIC_SITE_URL=

# (Optional) Fire a webhook on every new question (Discord/Slack). Leave empty to disable.
QUESTION_WEBHOOK_URL=
