# 이 파일을 복사해 .env 로 만들고 값을 채우세요. (또는 키입력.bat / 깃토큰입력.bat 사용)
# .env 는 절대 커밋되지 않습니다(.gitignore).

# 리서치·글 생성 (필수) — platform.openai.com/api-keys (카드 등록 + 소액 충전)
OPENAI_API_KEY=sk-...

# 발행(git push)용 GitHub 토큰 (사이트 연결 후) — fine-grained PAT, contents:write 권한
GITHUB_TOKEN=

# IndexNow 색인 키 (사이트키생성.bat 이 자동 생성) — site/public/<키>.txt 와 같아야 함
INDEXNOW_KEY=

# 🖼 이미지(Unsplash) — bigCategory/cluster 대표 비주얼. **admin(서버) 전용**.
#   unsplash.com/developers → New Application → Access Key / Secret Key 복사.
#   실제 키는 .env(.local) 에만 두세요. 사이트(Next)/클라이언트 번들에는 절대 들어가지 않습니다
#   (사진은 Unsplash URL 을 그대로 hotlink 로 표시하고, 검색·download 트리거는 admin 서버에서만 호출).
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=
UNSPLASH_APP_NAME=daebak
UNSPLASH_API_BASE=https://api.unsplash.com

# (선택) 리서치 엔진을 Gemini/Perplexity 로 바꿀 때만
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# ❓ 질문 인박스(Supabase) — 외국인이 로그인 없이 남긴 질문 저장소. site 와 admin 이 공유.
#   supabase.com → New project → SQL Editor 에 supabase/questions.sql 실행 → Settings>API 에서 복사.
#   ⚠️ service_role 키는 서버 전용(절대 client/site 번들에 안 들어감). 같은 값을 Vercel 프로젝트 env 에도 넣으세요.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# 랜덤 문자열(IP 해시용 솔트) — 아무 값이나. 한 번 정하면 바꾸지 마세요.
QUESTION_IP_SALT=

# 📧 답변 발행 시 이메일 알림(선택, Resend). 없어도 사이트/admin 안 깨짐(수동 상태변경 가능).
EMAIL_PROVIDER=resend
RESEND_API_KEY=
QUESTION_FROM_EMAIL=
# (선택) 새 질문 알림 받을 내 이메일 / 웹훅(Discord·Slack 등). 없어도 됨.
QUESTION_NOTIFY_EMAIL=
QUESTION_WEBHOOK_URL=
